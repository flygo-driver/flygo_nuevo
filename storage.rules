rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    /* ========= Helpers ========= */
    function signedIn() { return request.auth != null; }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }

    /* ========= AVATARES =========
       Ruta: perfiles/{uid}/avatar_*.jpg
       Lectura: cualquiera autenticado
       Escritura: solo el dueño, máx 5MB, solo imagen
    */
    match /perfiles/{uid}/{fileName} {
      allow read: if signedIn();
      allow write: if isOwner(uid)
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    /* ========= DOCUMENTOS TAXISTA =========
       Ruta: documentos_taxista/{uid}/{fileName}
       Lectura/Escritura: solo el dueño
       Máx 10MB, imagen o PDF
    */
    match /documentos_taxista/{uid}/{fileName} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid)
                   && request.resource.size < 10 * 1024 * 1024
                   && (
                        request.resource.contentType.matches('image/.*') ||
                        request.resource.contentType == 'application/pdf'
                      );
    }

    /* ========= COMPROBANTES DE DEPÓSITO (POOLS) =========
       Ruta: comprobantes/{uid}/{reservaId}/{fileId}
       Lectura/Escritura: solo el dueño
       Máx 5MB, imagen o PDF
       (El admin leerá esto desde Admin SDK, que no está limitado por reglas)
    */
    match /comprobantes/{uid}/{reservaId}/{fileId} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid)
                   && request.resource.size < 5 * 1024 * 1024
                   && (
                        request.resource.contentType.matches('image/.*') ||
                        request.resource.contentType == 'application/pdf'
                      );
    }

    /* ========= Bloqueo por defecto ========= */
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
