rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    /* ========= Helpers ========= */
    function signedIn() { return request.auth != null; }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }

    /* ========= AVATARES =========
       Ruta: perfiles/{uid}/avatar_*.jpg
       Lectura: cualquiera autenticado
       Escritura: solo el dueño, máx 5MB, solo imagen
    */
    match /perfiles/{uid}/{fileName} {
      allow read: if signedIn();
      allow write: if isOwner(uid)
                   && request.resource != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    /* ========= DOCUMENTOS TAXISTA (naming antiguo) =========
       Ruta: documentos_taxista/{uid}/{fileName}
       Lectura/Escritura: solo el dueño, máx 10MB, imagen o PDF
    */
    match /documentos_taxista/{uid}/{fileName} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid)
                   && request.resource != null
                   && request.resource.size < 10 * 1024 * 1024
                   && (
                        request.resource.contentType.matches('image/.*') ||
                        request.resource.contentType == 'application/pdf'
                      );
    }

    /* ========= RUTAS NUEVAS USADAS POR LA APP =========
       users/{uid}/documentos/...  y  taxistas/{uid}/documentos/...
       Lectura: autenticados
       Escritura: dueño, máx 10MB, imagen o PDF
    */
    match /users/{uid}/documentos/{allPaths=**} {
      allow read: if signedIn();
      allow write: if isOwner(uid)
                   && request.resource != null
                   && request.resource.size < 10 * 1024 * 1024
                   && (
                        request.resource.contentType.matches('image/.*') ||
                        request.resource.contentType == 'application/pdf'
                      );
    }

    match /taxistas/{uid}/documentos/{allPaths=**} {
      allow read: if signedIn();
      allow write: if isOwner(uid)
                   && request.resource != null
                   && request.resource.size < 10 * 1024 * 1024
                   && (
                        request.resource.contentType.matches('image/.*') ||
                        request.resource.contentType == 'application/pdf'
                      );
    }

    /* ========= COMPROBANTES DE DEPÓSITO (POOLS) =========
       Ruta: comprobantes/{uid}/{reservaId}/{fileId}
       Lectura/Escritura: solo el dueño, máx 5MB, imagen o PDF
       (El admin puede leer con Admin SDK)
    */
    match /comprobantes/{uid}/{reservaId}/{fileId} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid)
                   && request.resource != null
                   && request.resource.size < 5 * 1024 * 1024
                   && (
                        request.resource.contentType.matches('image/.*') ||
                        request.resource.contentType == 'application/pdf'
                      );
    }

    /* ========= Firmas de recibos (FirmarPago) ========= */
    match /firmas/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn()
                   && request.resource != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType == 'image/png';
    }

    /* ========= Pools turismo: logos / banners (pools_taxista_crear) ========= */
    match /agencias/{uid}/{fileName} {
      allow read: if signedIn();
      allow write: if isOwner(uid)
                   && request.resource != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    match /viajes_pool/{uid}/{fileName} {
      allow read: if signedIn();
      allow write: if isOwner(uid)
                   && request.resource != null
                   && request.resource.size < 50 * 1024 * 1024
                   && (
                        request.resource.contentType.matches('image/.*') ||
                        request.resource.contentType.matches('video/.*')
                      );
    }

    /* ========= Bloqueo por defecto ========= */
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
